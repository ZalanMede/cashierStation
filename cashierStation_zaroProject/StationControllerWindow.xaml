<Window x:Class="cashierStation_zaroProject.StationControllerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:cashierStation_zaroProject"
        mc:Ignorable="d"
        Title="StationControllerWindow"
        Height="450"
        Width="800"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize">
    <Window.Resources>
        <ResourceDictionary>
            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="TextAlignment" Value="Center"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Padding" Value="22, 17"/>
                <Setter Property="FontSize" Value="10"/>
            </Style>
            <Style TargetType="Button">
                <Setter Property="Background" Value="ForestGreen"/>
                <Setter Property="Foreground" Value="White"></Setter>
                <Setter Property="FontSize" Value="18"/>
            </Style>
            <Style TargetType="TextBox">
                <Setter Property="Width" Value="250"/>
                <Setter Property="Height" Value="25"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>
    <DockPanel
        Background="LightGray"
        Width="800"
        Height="400">
        <StackPanel
            DockPanel.Dock="Left"
            Width="200"></StackPanel>
        <StackPanel>
            <TextBox
            x:Name="numInputTxtBox"
            IsEnabled="False"/>

            <Grid DockPanel.Dock="Right"
                Margin="0, 50">
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="50"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="50"/>
                </Grid.ColumnDefinitions>
                <Button
                    Grid.Row="0"
                    Grid.Column="0"
                    Click="NumButton_Click"
                    Content="1">    
                </Button>
                <Button
                    Grid.Row="0"
                    Grid.Column="1"
                    Click="NumButton_Click"
                    Content="2">
                </Button>
                <Button
                    Grid.Row="0"
                    Grid.Column="2"
                    Click="NumButton_Click"
                    Content="4">
                </Button>
                <Button
                    Grid.Row="1"
                    Grid.Column="0"
                    Click="NumButton_Click"
                    Content="4">
                </Button>
                <Button
                    Grid.Row="1"
                    Grid.Column="1"
                    Click="NumButton_Click"
                    Content="5">
                </Button>
                <Button
                    Grid.Row="1"
                    Grid.Column="2"
                    Click="NumButton_Click"
                    Content="6">
                </Button>
                <Button
                    Grid.Row="2"
                    Grid.Column="0"
                    Click="NumButton_Click"
                    Content="7">
                </Button>
                <Button
                    Grid.Row="2"
                    Grid.Column="1"
                    Click="NumButton_Click"
                    Content="8">
                </Button>
                <Button
                    Grid.Row="2"
                    Grid.Column="2"
                    Click="NumButton_Click"
                    Content="9">
                </Button>
                <Button
                Grid.Row="3"
                Grid.Column="0"
                x:Name="numDel"
                Click="numDel_Click">
                    <TextBlock
                        Text="DEL"
                        Padding="17, 18.5"/>
                </Button>
                <Button
                    Grid.Row="3"
                    Grid.Column="1"
                    Click="NumButton_Click"
                    Content="0">
                </Button>
                <Button
                    Grid.Row="3"
                    Grid.Column="2"
                    x:Name="numEnter"
                    Click="numEnter_Click">
                    <TextBlock
                        Text="ENTER"
                        Padding="11, 18.5"/>
                </Button>
            </Grid>
        </StackPanel>


        
    </DockPanel>
</Window>
