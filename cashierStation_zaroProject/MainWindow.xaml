<Window x:Class="cashierStation_zaroProject.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:cashierStation_zaroProject"
        mc:Ignorable="d"
        Title="Login"
        Height="550"
        Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        Foreground="AliceBlue"
        FontSize="25"
        Background="SlateGray">
    <StackPanel
        Margin="15">
        <TextBlock
            Text="Cashier Station User Login"
            VerticalAlignment="Top"
            HorizontalAlignment="Center"
            Padding="5"
            FontSize="30"
            FontWeight="Bold"/>
        <Grid VerticalAlignment="Center"
              Margin="0, 50, 0, 0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock
                Grid.Row="0"
                HorizontalAlignment="Left"
                Text="Felhasználónév" />
            <TextBox
                x:Name="loginUserInTxt"
                Grid.Row="1"
                Width="350"
                HorizontalAlignment="Left"
                Background="LightGray" />
            <TextBlock
                Grid.Row="2"
                HorizontalAlignment="Left"
                Text="Jelszó" />
            <PasswordBox
                x:Name="loginPasswordInTxt"
                Grid.Row="3"
                Width="350"
                HorizontalAlignment="Left"
                Background="LightGray" />
            <TextBlock
                Grid.Row="4"
                HorizontalAlignment="Right"
                FontSize="14"
                FontStyle="Italic"
                Foreground="LightCyan"
                Text="Elfelejtett jelszó" />
            <Button
                x:Name="loginBtn"
                Grid.Row="5"
                Width="250"
                Height="50"
                Margin="0,60,0,0"
                Background="DarkCyan"
                Content="Bejelentkezés"
                Foreground="WhiteSmoke"
                Click="loginBtn_Click"/>
        </Grid>
    </StackPanel>
</Window>
